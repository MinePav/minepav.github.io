  header {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 20px 7%;
}

.logo {
    cursor: pointer;
    margin-right: auto;
    text-decoration: none;
    color: #edf0f1;
}

.nav_links { list-style: none }

.nav_item {
    display: inline-block;
    position: relative;
    padding: 0px 25px;
}

.nav_link {
    color: #edf0f1;
    text-decoration: none;
    transition: all 0.3s ease 0s;
}

.nav_link:hover { color: #0088a9; }

.nav_item:hover .dropdown {
    display: block;
    opacity: 1;
    transform: translateY(0);
}

.dropdown {
    display: block;
    opacity: 0;
    position: absolute;
    top: 100%;
    background-color: #25252a;
    padding: 10px 0;
    list-style: none;
    border: 2px solid #0088a9;
    border-radius: 20px;
    width: 190px;
    transform: translateY(-10px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
}

.nav_item:hover .dropdown { pointer-events: auto; }

.dropdown_item {
    border-radius: 10px;
    padding: 5px 15px;
    text-align: left;
}

.dropdown_item + .dropdown_item { margin-top: 5px; }

.dropdown_link {
    font-size: 23px;
    color: #edf0f1;
    text-decoration: none;
    display: block;
}

.dropdown_link:hover {
    color: #0088a9;
    background-color: #33333a;
    border-radius: 20px;
}








body {
  min-height: 100vh;
  background: var(--bg-color);
  color: var(--text-color); 
}
header {
  position: fixed;
  width: 100%;
  top: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: transparent;
  padding: 28px 12%;
  transition: all 0.5s ease;
}
.logo {
  display: flex;
  align-items: center;
}
.logo i {
  color: var(--main-color);
  font-size: 35px;
  margin-right: 5px;
  padding-top: 10px;
}
.logo span {
  color: var(--text-color);
  font-size: 1.7rem;
}
.navbar {
  display: flex;
}
.navbar a {
  color: var(--text-color);
  font-size: 1.1rem;
  padding: 5px 0;
  margin: 0px 30px;
  transition: all 0.5s ease;
}
.navbar a:hover {
  color: var(--main-color);
}
.navbar a.active {
  color: var(--main-color);
}
.main {
  display: flex;
  align-items: center;
}
.main a {
  margin-right: 25px;
  margin-left: 10px;
  color: var(--text-color);
  font-size: 1.1rem;
  transition: all 0.5s ease;
}
.user {
  display: flex;
  align-items: center;
}
.user i {
  color: var(--main-color);
  font-size: 28px;
  margin-right: 7px;
}
.main a:hover {
  color: var(--main-color);
}
#menu-icon {
  font-size: 35px;
  color: var(--text-color);
  cursor: pointer;
  z-index: 10001;
  display: none;
}
@media (max-width: 1280px) {
  header {
      padding: 14px 2%;
      transition: .2s;
  }
  .navbar {
      padding: 5px 0;
      margin: 0px 20px;  
  }
}
@media (max-width: 1090px) {

  .logo span {
      font-size: 25px;
  }
  #menu-icon {
      display: block;
  }
  .navbar {
      position: absolute;
      top: 100%;
      right: -100%;
      width: 270px;
      height: 29vh;
      background: var(--main-color);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      border-radius: 10px;
      transition: all 0.5s ease;
  }
  .navbar a {
      display: block;
      margin: 12px 0;
      padding: 0px 25px;
      transition: all 0.5s ease;
  }
  .navbar a:hover {
      color: var(--text-color);
      transform: translateY(5px);
  }
  .navbar a.active {
      color: var(--text-color);
  }
  .navbar.open {
      right: 2%;
  }
}
:root{
  --bg-color: #222327;
  --text-color: #fff;
  --main-color: #00c026;
}